{
  "name": "@cgx/layer",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./provider/xyz": {
      "development": "./src/provider/xyz.ts",
      "import": "./dist/provider/xyz.js",
      "types": "./dist/provider/xyz.d.ts"
    },
    "./provider/wms": {
      "development": "./src/provider/wms.ts",
      "import": "./dist/provider/wms.js",
      "types": "./dist/provider/wms.d.ts"
    },
    "./provider/wmts": {
      "development": "./src/provider/wmts.ts",
      "import": "./dist/provider/wmts.js",
      "types": "./dist/provider/wmts.d.ts"
    },
    "./provider/singleTile": {
      "development": "./src/provider/singleTile.ts",
      "import": "./dist/provider/singleTile.js",
      "types": "./dist/provider/singleTile.d.ts"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "size": "size-limit"
  },
  "dependencies": {
    "@cgx/core": "workspace:*",
    "@cgx/feature": "workspace:*",
    "@cgx/reactive": "workspace:*"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.1.0",
    "@vitest/coverage-v8": "^2.1.9",
    "happy-dom": "^20.9.0",
    "size-limit": "^12.1.0",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cgx/cgx.git",
    "directory": "packages/layer"
  },
  "author": "CGX Team"
}
